# Скопируйте в `.env` или `.env.local` для разработки.
# В Docker задайте через `docker compose --env-file .env` или переменные в compose.

# Обязательно: длинная случайная строка (iron-session), минимум 32 символа.
SB_SECRET=

# Опционально: требовать подтверждение email после регистрации.
AUTH_EMAIL_REQUIRED=false

# Базовый URL приложения для ссылок в письмах.
# Обязательно в production (verify/reset/invite email ссылки).
APP_BASE_URL=

# Вариант 1 отправки писем: Resend.
RESEND_API_KEY=
MAIL_FROM=

# Вариант 2 отправки писем: SMTP Яндекс 360.
YANDEX_SMTP_USER=
YANDEX_SMTP_APP_PASSWORD=
YANDEX_SMTP_HOST=smtp.yandex.com
YANDEX_SMTP_PORT=465

# Вариант 3 отправки писем: внешний webhook.
MAIL_WEBHOOK_URL=
MAIL_WEBHOOK_TOKEN=

# Яндекс SmartCaptcha (включается, если задан server key).
NEXT_PUBLIC_YANDEX_SMARTCAPTCHA_SITE_KEY=
YANDEX_SMARTCAPTCHA_SERVER_KEY=
